# Copy to .env.n8n and fill in real values:
#   cp .env.n8n.example .env.n8n
# Never commit the resulting .env.n8n file.
#
# N8N_ENCRYPTION_KEY is critical: if it ever changes, all stored credentials
# become unreadable. Generate once with: openssl rand -hex 32

# ── n8n: Postgres (shares the existing postgres container) ─
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-me-to-a-strong-passphrase
N8N_DB_NAME=n8n

# ── n8n: app ───────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change-me-64-hex-chars-from-openssl-rand-hex-32
N8N_HOST=n8n.infra.*.com
N8N_TIMEZONE=Asia/Kolkata
