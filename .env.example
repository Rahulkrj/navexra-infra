# Copy to .env and fill in real values:
#   cp .env.example .env
# Never commit the resulting .env file.

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=pguser
POSTGRES_PASSWORD=change-me-to-a-strong-passphrase
POSTGRES_DB=appdb

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change-me-to-a-strong-passphrase
