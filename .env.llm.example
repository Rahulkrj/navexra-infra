# Copy to .env.llm and fill in real values:
#   cp .env.llm.example .env.llm
# Never commit the resulting .env.llm file.

# ── LiteLLM: gateway auth ──────────────────────────────────
# Master/admin key for the LiteLLM proxy. Used to mint per-client virtual
# keys and to reach the admin UI. Generate once: openssl rand -hex 32
# Convention: LiteLLM master keys are prefixed with "sk-".
LITELLM_MASTER_KEY=sk-change-me-to-a-strong-random-key
# Optional; defaults to LITELLM_MASTER_KEY if unset. Used to encrypt stored
# credentials in the DB — keep it stable. Generate once: openssl rand -hex 32
LITELLM_SALT_KEY=

# ── LiteLLM: Postgres (shares the existing postgres container) ─
LLM_DB_USER=litellm
LLM_DB_PASSWORD=change-me-to-a-strong-passphrase
LLM_DB_NAME=litellm

# ── Claude backend (claude-code-openai-wrapper) ────────────
# Subscription token (Claude Pro/Max). Mint on a machine with a browser:
#   npm i -g @anthropic-ai/claude-code && claude setup-token
# Valid ~1 year. See docs/ADD_LLM.md.
CLAUDE_CODE_OAUTH_TOKEN=change-me-claude-oauth-token
# Internal bearer LiteLLM uses to call the wrapper. Generate: openssl rand -hex 24
CLAUDE_WRAPPER_API_KEY=change-me-internal-bearer

# ── ChatGPT backend (codex-adapter) ────────────────────────
# No token needed here — credentials come from `codex login --device-auth`
# (stored in the codex_config docker volume). One-time, on the VPS:
#   docker compose -f docker-compose.llm.yml --env-file .env.llm \
#     run --rm codex-adapter codex login --device-auth
# Internal bearer LiteLLM uses to call the codex-adapter. Generate: openssl rand -hex 24
CODEX_ADAPTER_API_KEY=change-me-internal-bearer
# Optional: pin a model (empty = Codex CLI default, survives deprecations).
CODEX_MODEL=
# low | medium | high — low is faster, high is smarter.
CODEX_REASONING_EFFORT=low

# ── Cursor backend (cursor-adapter) — only needed for --profile cursor ──
# Cursor *User API key* from Cursor Dashboard → API Keys.
CURSOR_API_KEY=change-me-cursor-user-api-key
# Internal bearer LiteLLM uses to call the cursor-adapter. Generate: openssl rand -hex 24
CURSOR_ADAPTER_API_KEY=change-me-internal-bearer
# Default Cursor model when a request doesn't specify one.
CURSOR_MODEL=composer-2.5

# ── Host nginx vhost ───────────────────────────────────────
LLM_HOST=llm.infra.navexra.com
